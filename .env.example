# --- Broker (default: Alpaca paper) ---
BROKER=alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex
ALPACA_MOVERS_TOP=25

# --- Finnhub (free tier: today's earnings calendar + news) ---
FINNHUB_API_KEY=

# --- Interactive Brokers (only if BROKER=ibkr; TWS or IB Gateway must be running) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497            # 7497 = TWS paper, 7496 = TWS live, 4002 = Gateway paper, 4001 = Gateway live
IBKR_CLIENT_ID=17

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Supabase (optional; falls back to in-memory store if blank) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Trading rules (auto-trade on/off is toggled in the dashboard) ---
AUTO_TRADE_THRESHOLD=90
MAX_TRADES_PER_DAY=2
MAX_DAILY_LOSS=100
RISK_PER_TRADE=25
MAX_POSITION_SIZE=1000

# --- Candidate filters ---
MIN_GAP_PCT=8
MIN_RELATIVE_VOLUME=3
MIN_PRICE=5

# --- Dashboard ---
API_HOST=127.0.0.1
API_PORT=8000
